---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";

// Haal alle signals op en sorteer nieuwste eerst
const signals = await getCollection("signal");
signals.sort((a, b) => b.data.issue_number - a.data.issue_number);

// VUL HIER JOUW BEEHIIV URL IN:
const BEEHIIV_URL = "https://YOUR-NEWSLETTER-NAME.beehiiv.com/subscribe";
---

<BaseLayout title="The Signal | Arthur VO">
    <Header />

    <main
        class="mx-auto w-full max-w-3xl px-6 py-12 md:py-20 flex-grow relative z-10"
    >
        <div
            class="mb-12 border-b border-white/10 pb-8 flex flex-col md:flex-row md:items-end justify-between gap-8"
        >
            <div class="max-w-xl">
                <div
                    class="mb-4 inline-flex items-center gap-2 rounded border border-[#38BDF8]/30 bg-[#38BDF8]/10 px-3 py-1.5 text-[10px] font-bold uppercase tracking-[0.2em] text-[#38BDF8]"
                >
                    <span>Newsletter Archive</span>
                </div>
                <h1
                    class="text-3xl font-extrabold tracking-wide text-white md:text-5xl mb-4"
                >
                    The Signal
                </h1>
                <p class="text-slate-400 leading-relaxed">
                    The Signal is not a newsletter; it is a strategic directive
                    for B2B leaders. While the market drowns in the "AI Junk
                    Drawer," we filter the 5% of technology that delivers actual
                    impact. The remaining 95% is noise and must be purged.
                </p>
            </div>

            <a
                href={BEEHIIV_URL}
                target="_blank"
                rel="noreferrer"
                class="shrink-0 inline-flex items-center justify-center gap-2 rounded-lg bg-[#38BDF8] px-6 py-4 text-xs font-bold uppercase tracking-widest text-[#05050A] transition-all hover:bg-white hover:shadow-[0_0_20px_rgba(56,189,248,0.4)]"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M21.2 8.4c.5.38.8.97.8 1.6v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V10a2 2 0 0 1 .8-1.6l8-6a2 2 0 0 1 2.4 0l8 6Z"
                    ></path><path
                        d="m22 10-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 10"
                    ></path></svg
                >
                Subscribe to Feed
            </a>
        </div>

        <div class="flex flex-col gap-4">
            {
                signals.length === 0 ? (
                    <div class="flex items-center justify-center p-10 border border-white/5 rounded-xl bg-white/5">
                        <span class="text-slate-500 font-mono text-sm tracking-widest uppercase animate-pulse">
                            [ NO TRANSMISSIONS FOUND ]
                        </span>
                    </div>
                ) : (
                    signals.map(async (signal) => {
                        const { Content } = await signal.render();

                        return (
                            <article class="group relative flex flex-col gap-4 rounded-xl border border-white/5 bg-[#05050A]/80 p-6 backdrop-blur-md transition-all hover:border-[#38BDF8]/40 hover:bg-white/[0.02]">
                                <div class="flex items-start justify-between gap-4">
                                    <div class="flex items-center gap-4">
                                        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg border border-white/10 bg-black/60 font-mono text-xs font-bold text-[#38BDF8] shadow-[0_0_10px_rgba(0,0,0,0.5)] group-hover:border-[#38BDF8]/40 group-hover:shadow-[0_0_15px_rgba(56,189,248,0.2)] transition-all">
                                            #
                                            {String(
                                                signal.data.issue_number,
                                            ).padStart(3, "0")}
                                        </div>

                                        <div class="flex flex-col gap-1">
                                            <a
                                                href={signal.data.link}
                                                target="_blank"
                                                rel="noreferrer"
                                                class="text-lg font-bold text-white group-hover:text-[#38BDF8] transition-colors inline-flex items-center gap-2"
                                            >
                                                {signal.data.title}
                                                <svg
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    width="16"
                                                    height="16"
                                                    viewBox="0 0 24 24"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    class="opacity-0 -translate-x-2 transition-all group-hover:opacity-100 group-hover:translate-x-0"
                                                >
                                                    <>
                                                        <path d="M7 7h10v10" />
                                                        <path d="M7 17 17 7" />
                                                    </>
                                                </svg>
                                            </a>
                                            <span class="text-[10px] font-mono uppercase tracking-widest flex items-center gap-2">
                                                <span class="text-[#8B5CF6]">
                                                    [ SOURCE ]
                                                </span>
                                                <span class="text-slate-500">
                                                    BEEHIIV PLATFORM
                                                </span>
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <div class="pl-16 text-sm leading-relaxed text-slate-400">
                                    <Content />
                                </div>
                            </article>
                        );
                    })
                )
            }
        </div>
    </main>
</BaseLayout>
