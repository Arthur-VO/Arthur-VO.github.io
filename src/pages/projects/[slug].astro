---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";

// 1. Vertel Astro welke projectpagina's gegenereerd moeten worden
export async function getStaticPaths() {
  const projectEntries = await getCollection("projects");
  return projectEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// 2. Haal de specifieke data op voor dit project
const { entry } = Astro.props;
const { Content } = await entry.render();

// Formatteer de datums
const startDate = entry.data.startDate.toISOString().split("T")[0];
const endDate = entry.data.endDate
  ? entry.data.endDate.toISOString().split("T")[0]
  : "PRESENT";
---

<BaseLayout title={`${entry.data.title} | Projects`}>
  <Header />

  <main
    class="mx-auto w-full max-w-4xl px-6 py-12 md:py-20 relative z-10 flex-grow"
  >
    <a
      href="/projects"
      class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-[#38BDF8] transition-colors mb-8"
    >
      ← Return to Pipeline
    </a>

    <article
      class="module overflow-hidden bg-[#05050A]/80 border-white/10 shadow-2xl backdrop-blur-xl"
    >
      <header
        class="module-header border-b border-white/10 bg-white/5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 py-4"
      >
        <div class="flex items-center gap-3">
          <span class="text-[#38BDF8]"
            >[ SYS://PROJECTS/{entry.data.topic.toUpperCase()} ]</span
          >
          <span
            class="px-2 py-0.5 rounded text-[9px] font-bold uppercase tracking-widest border border-white/20 text-white/70"
          >
            {entry.data.status}
          </span>
        </div>
        <span class="text-white/40 font-mono text-[10px] tracking-widest">
          LIFECYCLE: {startDate} → {endDate}
        </span>
      </header>

      <div class="module-body p-6 md:p-10">
        <h1
          class="text-3xl md:text-5xl font-extrabold text-white mb-6 leading-tight"
        >
          {entry.data.title}
        </h1>

        <div
          class="mb-10 p-5 rounded-lg border border-[#8B5CF6]/20 bg-[#8B5CF6]/5 border-l-4 border-l-[#8B5CF6]"
        >
          <p
            class="project-tagline-human text-slate-300 text-sm md:text-base leading-relaxed"
          >
            <span
              class="text-[#8B5CF6] font-bold uppercase tracking-widest text-xs block mb-1"
              >Executive Summary</span
            >
            {entry.data.tagline_human}
          </p>
          <p
            class="project-tagline-tech text-slate-300 text-sm md:text-base leading-relaxed hidden font-mono"
          >
            <span
              class="text-[#8B5CF6] font-bold uppercase tracking-widest text-xs block mb-1"
              >Architecture Outline</span
            >
            > {entry.data.tagline_tech}
          </p>
        </div>

        <div class="flex flex-wrap gap-4 mb-12 pb-10 border-b border-white/10">
          <a
            href={entry.data.url}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 rounded bg-white/5 hover:bg-white/10 border border-white/10 px-4 py-2 text-xs font-bold uppercase tracking-widest text-white transition-all"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
              ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
            >
            View Repository
          </a>
        </div>

        <div class="prose-container text-slate-300 leading-relaxed space-y-6">
          <Content />
        </div>
      </div>
    </article>
  </main>
</BaseLayout>

<style is:global>
  /* --- DYNAMISCHE TAGLINE --- */
  html[data-mode="human"] .project-tagline-tech {
    display: none;
  }
  html[data-mode="human"] .project-tagline-human {
    display: block;
  }

  html[data-mode="tech"] .project-tagline-human {
    display: none;
  }
  html[data-mode="tech"] .project-tagline-tech {
    display: block;
  }

  /* --- ZELFDE STYLING ALS BLOG --- */
  .prose-container h2 {
    font-size: 1.5rem;
    font-weight: bold;
    color: white;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose-container h3 {
    font-size: 1.25rem;
    font-weight: bold;
    color: white;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-container p {
    margin-bottom: 1.25rem;
  }
  .prose-container a {
    color: #38bdf8;
    text-decoration: none;
    border-bottom: 1px dashed rgba(56, 189, 248, 0.4);
    transition: all 0.2s ease-in-out;
  }
  .prose-container a:hover {
    border-bottom-style: solid;
    color: white;
    text-shadow: 0 0 8px rgba(56, 189, 248, 0.6);
  }
  .prose-container strong {
    color: white;
  }
  .prose-container ul {
    list-style-type: square;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    color: #8b5cf6;
  }
  .prose-container ul li span {
    color: #cbd5e1;
  }

  /* --- TECH MODE OVERRIDES VOOR MARKDOWN --- */
  html[data-mode="tech"] .prose-container {
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.9rem;
  }
  html[data-mode="tech"] .prose-container h2::before {
    content: "## ";
    color: #8b5cf6;
  }
  html[data-mode="tech"] .prose-container h3::before {
    content: "### ";
    color: #8b5cf6;
  }
</style>
