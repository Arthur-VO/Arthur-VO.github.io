---
import ModeToggle from "./ModeToggle";
---

<header class="mx-auto w-full max-w-5xl px-6 pt-6 relative z-50">
  <section class="module">
    <div class="module-header">
      <span>DEVICE://ROOT/CONTROL</span>
      <span class="hidden sm:inline-block text-white/30">SYS.VER: 2.0.26</span>
    </div>

    <div
      class="module-body flex flex-row items-center justify-between gap-4 py-4"
    >
      <a
        href="/"
        class="identity-link text-xs font-bold uppercase tracking-[0.22em] transition-all shrink-0"
        aria-label="Return to Root Directory"
      >
        HOME
      </a>

      <nav
        class="hidden md:flex flex-wrap justify-center items-center gap-8 text-xs font-bold uppercase tracking-widest text-slate-400"
      >
        <a
          href="/projects"
          class="py-2 px-3 transition-colors hover:text-[#38BDF8] hover:drop-shadow-[0_0_8px_rgba(56,189,248,0.4)]"
        >
          <span class="text-white/20 mr-1">/</span>Projects
        </a>
        <a
          href="/blog"
          class="py-2 px-3 transition-colors hover:text-[#38BDF8] hover:drop-shadow-[0_0_8px_rgba(56,189,248,0.4)]"
        >
          <span class="text-white/20 mr-1">/</span>Knowledge
        </a>
        <a
          href="/signal"
          class="py-2 px-3 transition-colors hover:text-[#38BDF8] hover:drop-shadow-[0_0_8px_rgba(56,189,248,0.4)]"
        >
          <span class="text-white/20 mr-1">/</span>Signal
        </a>
      </nav>

      <div class="flex items-center gap-4 shrink-0">
        <div
          class="hidden md:flex items-center gap-3 text-xs font-bold uppercase tracking-widest text-slate-500 pr-4 border-r border-white/10"
        >
          <a
            href="https://github.com/Arthur-VO"
            target="_blank"
            rel="noreferrer"
            class="py-2 px-2 hover:text-white transition-colors">GH</a
          >
          <a
            href="https://linkedin.com"
            target="_blank"
            rel="noreferrer"
            class="py-2 px-2 hover:text-white transition-colors">IN</a
          >
        </div>
        <ModeToggle client:load transition:persist />
      </div>
    </div>
  </section>
</header>
