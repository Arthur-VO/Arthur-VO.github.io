---
const currentPath = Astro.url.pathname;

const tabs = [
  {
    label: "Home",
    href: "/",
    match: (path: string) => path === "/",
    icon: "home",
  },
  {
    label: "Projects",
    href: "/projects",
    match: (path: string) => path.startsWith("/projects"),
    icon: "projects",
  },
  {
    label: "Knowledge",
    href: "/blog",
    match: (path: string) =>
      path.startsWith("/blog") || path.startsWith("/tags"),
    icon: "knowledge",
  },
  {
    label: "Signal",
    href: "/signal",
    match: (path: string) => path.startsWith("/signal"),
    icon: "signal",
  },
];
---

<nav
  class="fixed bottom-0 inset-x-0 z-50 md:hidden border-t border-white/10 bg-[#05050A]/90 backdrop-blur-xl safe-bottom"
  aria-label="Mobile navigation"
>
  <div class="flex items-stretch justify-around">
    {
      tabs.map((tab) => {
        const active = tab.match(currentPath);
        return (
          <a
            href={tab.href}
            class:list={[
              "flex flex-col items-center justify-center gap-1 flex-1 min-h-[56px] py-2 text-[10px] font-bold uppercase tracking-widest transition-colors",
              active
                ? "text-[#38BDF8]"
                : "text-slate-500 active:text-slate-300",
            ]}
            aria-current={active ? "page" : undefined}
          >
            {/* Home icon */}
            {tab.icon === "home" && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8" />
                <path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
              </svg>
            )}
            {/* Projects icon (git-branch) */}
            {tab.icon === "projects" && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="6" x2="6" y1="3" y2="15" />
                <circle cx="18" cy="6" r="3" />
                <circle cx="6" cy="18" r="3" />
                <path d="M18 9a9 9 0 0 1-9 9" />
              </svg>
            )}
            {/* Knowledge icon (brain/network) */}
            {tab.icon === "knowledge" && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 2a4 4 0 0 1 4 4c0 1.95-1.4 3.58-3.25 3.93" />
                <path d="M8.24 9.93A4 4 0 0 1 12 2" />
                <path d="M12 9v4" />
                <path d="m8 13 4 4 4-4" />
                <path d="M5.1 12.5A6.5 6.5 0 0 0 12 19.5a6.5 6.5 0 0 0 6.9-7" />
                <circle cx="12" cy="22" r="1" />
              </svg>
            )}
            {/* Signal icon (radio) */}
            {tab.icon === "signal" && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9" />
                <path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.4" />
                <circle cx="12" cy="12" r="2" />
                <path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.4" />
                <path d="M19.1 4.9C23 8.8 23 15.1 19.1 19" />
              </svg>
            )}
            <span>{tab.label}</span>

            {/* Active indicator dot */}
            {active && (
              <span class="absolute bottom-1 h-1 w-1 rounded-full bg-[#38BDF8] shadow-[0_0_6px_rgba(56,189,248,0.6)]" />
            )}
          </a>
        );
      })
    }
  </div>
</nav>

<style>
  /* Safe area padding for devices with home indicators (iPhone X+) */
  .safe-bottom {
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }

  nav a {
    position: relative;
    -webkit-tap-highlight-color: transparent;
  }
</style>
